--- 
import { ClientRouter } from 'astro:transitions';

interface Props {
	title: string;
}

const { title } = Astro.props;
import '@/styles/globals.css'
import ThemeProvider from '@/components/ThemeProvider.jsx'
import SidebarRoot from '@/components/SidebarRoot.jsx'
import CustomThemeStyle from '@/components/CustomThemeStyle.jsx'
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description">
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<script is:inline>
			// Apply the persisted custom theme before first paint (FOUC-free),
			// mirroring how the dark-mode class is applied. Re-applies across
			// Astro view transitions.
			//
			// IMPORTANT: the style element MUST be the LAST child of <head>. The
			// compiled Layout.css also defines default --accent-* variables on
			// :root, and a normal :root rule that appears LATER in the document
			// wins the cascade. If this element were inserted early (e.g. by this
			// inline script at parse time, before the Layout.css <link>), the
			// purple defaults from Layout.css would override the per-page accent
			// (turning instant trade purple instead of amber) on a full reload /
			// language switch. Appending last guarantees our theme always wins.
			(function () {
				function applyCustomTheme() {
					try {
						var raw = localStorage.getItem("btsThemeActiveCss");
						var css = raw ? JSON.parse(raw) : "";
						var el = document.getElementById("custom-theme-vars");
						if (!el) {
							el = document.createElement("style");
							el.id = "custom-theme-vars";
						}
						el.textContent = css || "";
						// Always keep it as the final node in <head> so it wins
						// the cascade over Layout.css's default --accent-* vars.
						document.head.appendChild(el);
					} catch (e) {}
				}
				applyCustomTheme();
				if (!window.__customThemeInit) {
					window.__customThemeInit = true;
					document.addEventListener("astro:after-swap", applyCustomTheme);
				}
			})();
		</script>
		<ClientRouter />
	</head>
	<body>
		<ThemeProvider client:only="react">
			<CustomThemeStyle client:only="react" />
			<SidebarRoot client:only="react">
				<slot />
			</SidebarRoot>
		</ThemeProvider>
	</body>
</html>
<style is:global>
	:root {
		--accent: 136, 58, 234;
		--accent-light: 224, 204, 250;
		--accent-dark: 49, 10, 101;
		--accent-gradient: linear-gradient(45deg, rgb(var(--accent)), rgb(var(--accent-light)) 30%, rgb(var(--background)) 60%);
	}
	html {
		font-family: system-ui, sans-serif;
	}
	code {
		font-family: Menlo, Monaco, Lucida Console, Liberation Mono, DejaVu Sans Mono,
			Bitstream Vera Sans Mono, Courier New, monospace;
	}
	body {
		min-height: 100%;
		background: hsl(var(--background));
		background-size: 224px;
	}
	main {
		margin: auto;
		padding: 1rem;
		width: 100%;
		max-width: calc(100% - 2rem);
		color: hsl(var(--foreground));
		font-size: 20px;
		line-height: 1.6;
		min-height: 100vh;
	}
</style>
