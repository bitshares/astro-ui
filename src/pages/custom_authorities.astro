---
import Layout from '../layouts/Layout.astro';
import CustomAuthorities from '../components/CustomAuthorities.jsx';
import PageHeader from '../components/PageHeader';
import PageFooter from '../components/PageFooter';
---

<Layout title="Custom Authorities">
	<main>
		<PageHeader client:only="react" page="custom_authorities" />
		<CustomAuthorities client:only="react" />
		<PageFooter client:only="react" sourceURL="https://github.com/BTS-CM/astro-ui/blob/main/src/pages/custom_authorities.astro" />
	</main>
</Layout>

<style>
	main {
		margin: auto;
		padding: 1rem;
		width: 100%;
		max-width: calc(100% - 2rem);
		color: hsl(var(--foreground));
		font-size: 20px;
		line-height: 1.6;
		min-height: 100vh;
	}
</style>
