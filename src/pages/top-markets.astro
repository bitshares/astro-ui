---
import Layout from '../layouts/Layout.astro';
import BlockchainTopMarkets from '../components/BlockchainTopMarkets.jsx';
import PageHeader from '../components/PageHeader';
import PageFooter from '../components/PageFooter';
---

<Layout title="Top Markets">
	<main>
		<PageHeader client:only="react" page="top-markets" />
		<BlockchainTopMarkets client:only="react" />
		<PageFooter client:only="react" sourceURL="https://github.com/BTS-CM/astro-ui/blob/main/src/pages/top-markets.astro" />
	</main>
</Layout>

<style>
	main {
		margin: auto;
		padding: 1rem;
		width: 100%;
		max-width: calc(100% - 2rem);
		color: hsl(var(--foreground));
		font-size: 20px;
		line-height: 1.6;
		min-height: 100vh;
	}
</style>
